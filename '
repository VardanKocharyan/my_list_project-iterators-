#include "my_list.hpp"

int main() {
    my_list<int> a;//default
    my_list<int> b(5, 6);//parameter
    my_list<int> c(b);//copy ctor
    my_list<int> d {1, 2, 3, 4, 5, 6};

  
    std::cout << "b: " <<  b << std::endl;
    std::cout << "c: " <<  c << std::endl;
    std::cout << "d: " <<  d << std::endl; 


    return 0;
}

